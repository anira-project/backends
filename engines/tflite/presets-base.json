{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },

  "vendor": {
    "anira": {
      "doc": "Hidden platform/lib-type bases for tflite, shared by engines/tflite/CMakePresets.json (standalone tflite dev) and the root CMakePresets.json (which builds tflite via the orchestrator). Kept in one file so neither duplicates the platform matrix."
    }
  },

  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" },
      "environment": { "CMAKE_POLICY_VERSION_MINIMUM": "3.5" }
    },
    { "name": "ninja",  "hidden": true, "inherits": "base", "generator": "Ninja" },
    { "name": "shared", "hidden": true, "cacheVariables": { "TFLITE_BUILD_STATIC": "OFF" } },
    { "name": "static", "hidden": true, "cacheVariables": { "TFLITE_BUILD_STATIC": "ON"  } },

    {
      "name": "macos-x64", "hidden": true, "inherits": "ninja",
      "cacheVariables": { "CMAKE_OSX_ARCHITECTURES": "x86_64", "CMAKE_OSX_DEPLOYMENT_TARGET": "11.0" }
    },
    {
      "name": "macos-arm64", "hidden": true, "inherits": "ninja",
      "cacheVariables": { "CMAKE_OSX_ARCHITECTURES": "arm64", "CMAKE_OSX_DEPLOYMENT_TARGET": "11.0" }
    },
    { "name": "linux-x64", "hidden": true, "inherits": "ninja" },
    {
      "name": "linux-arm64", "hidden": true, "inherits": "ninja",
      "cacheVariables": { "CMAKE_SYSTEM_NAME": "Linux", "CMAKE_SYSTEM_PROCESSOR": "aarch64" }
    },
    { "name": "windows-x64",   "hidden": true, "inherits": "ninja" },
    { "name": "windows-arm64", "hidden": true, "inherits": "ninja" },
    {
      "name": "android-arm64", "hidden": true, "inherits": "ninja",
      "toolchainFile": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
      "cacheVariables": { "ANDROID_ABI": "arm64-v8a", "ANDROID_PLATFORM": "android-24" }
    },
    {
      "name": "android-x64", "hidden": true, "inherits": "ninja",
      "toolchainFile": "$env{ANDROID_NDK_HOME}/build/cmake/android.toolchain.cmake",
      "cacheVariables": { "ANDROID_ABI": "x86_64", "ANDROID_PLATFORM": "android-24" }
    },
    {
      "name": "wasm", "hidden": true, "inherits": "ninja",
      "toolchainFile": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake"
    }
  ]
}
