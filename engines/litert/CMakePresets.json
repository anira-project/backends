{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },

  "include": ["presets-base.json"],

  "configurePresets": [
    { "name": "macos-x64-shared",     "inherits": ["macos-x64", "shared"] },
    { "name": "macos-x64-static",     "inherits": ["macos-x64", "static"] },
    { "name": "macos-arm64-shared",   "inherits": ["macos-arm64", "shared"] },
    { "name": "macos-arm64-static",   "inherits": ["macos-arm64", "static"] },
    { "name": "linux-x64-shared",     "inherits": ["linux-x64", "shared"] },
    { "name": "linux-x64-static",     "inherits": ["linux-x64", "static"] },
    { "name": "linux-arm64-shared",   "inherits": ["linux-arm64", "shared"] },
    { "name": "linux-arm64-static",   "inherits": ["linux-arm64", "static"] },
    { "name": "windows-x64-shared",   "inherits": ["windows-x64", "shared"] },
    { "name": "windows-x64-static",   "inherits": ["windows-x64", "static"] },
    { "name": "windows-x64-static-debug",   "inherits": ["windows-x64", "static"],   "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" } },
    { "name": "windows-arm64-shared", "inherits": ["windows-arm64", "shared"] },
    { "name": "windows-arm64-static", "inherits": ["windows-arm64", "static"] },
    { "name": "windows-arm64-static-debug", "inherits": ["windows-arm64", "static"], "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" } },
    { "name": "android-arm64-shared", "inherits": ["android-arm64", "shared"] },
    { "name": "android-arm64-static", "inherits": ["android-arm64", "static"] },
    { "name": "android-x64-shared",   "inherits": ["android-x64", "shared"] },
    { "name": "android-x64-static",   "inherits": ["android-x64", "static"] },
    { "name": "wasm-static",          "inherits": ["wasm", "static"] }
  ],

  "buildPresets": [
    { "name": "macos-x64-shared",     "configurePreset": "macos-x64-shared",     "configuration": "Release" },
    { "name": "macos-x64-static",     "configurePreset": "macos-x64-static",     "configuration": "Release" },
    { "name": "macos-arm64-shared",   "configurePreset": "macos-arm64-shared",   "configuration": "Release" },
    { "name": "macos-arm64-static",   "configurePreset": "macos-arm64-static",   "configuration": "Release" },
    { "name": "linux-x64-shared",     "configurePreset": "linux-x64-shared",     "configuration": "Release" },
    { "name": "linux-x64-static",     "configurePreset": "linux-x64-static",     "configuration": "Release" },
    { "name": "linux-arm64-shared",   "configurePreset": "linux-arm64-shared",   "configuration": "Release" },
    { "name": "linux-arm64-static",   "configurePreset": "linux-arm64-static",   "configuration": "Release" },
    { "name": "windows-x64-shared",   "configurePreset": "windows-x64-shared",   "configuration": "Release" },
    { "name": "windows-x64-static",   "configurePreset": "windows-x64-static",   "configuration": "Release" },
    { "name": "windows-x64-static-debug",   "configurePreset": "windows-x64-static-debug",   "configuration": "Debug" },
    { "name": "windows-arm64-shared", "configurePreset": "windows-arm64-shared", "configuration": "Release" },
    { "name": "windows-arm64-static", "configurePreset": "windows-arm64-static", "configuration": "Release" },
    { "name": "windows-arm64-static-debug", "configurePreset": "windows-arm64-static-debug", "configuration": "Debug" },
    { "name": "android-arm64-shared", "configurePreset": "android-arm64-shared", "configuration": "Release" },
    { "name": "android-arm64-static", "configurePreset": "android-arm64-static", "configuration": "Release" },
    { "name": "android-x64-shared",   "configurePreset": "android-x64-shared",   "configuration": "Release" },
    { "name": "android-x64-static",   "configurePreset": "android-x64-static",   "configuration": "Release" },
    { "name": "wasm-static",          "configurePreset": "wasm-static",          "configuration": "Release" }
  ]
}
