# build outputs
**/build/
dist/
staging/
artifacts/

# tooling
emsdk-cache-*/
.DS_Store

# onnxruntime build
engines/onnxruntime/onnxruntime-src/

# executorch from-source clone (recursive submodules — large). Leaf must be named exactly
# `executorch` (upstream issue 6475); nested under src/ so the engine's VERSION file isn't
# on the include path (case-insensitive clash with C++20 <version>).
engines/executorch/src/
# pytorch source built on Intel mac only, to generate torch headers (no x86_64 wheel)
engines/executorch/pytorch-src/

# litert stage.sh header-source scratch (fetched per-mode: SDK zip for build, repo tarball for prebuilt)
engines/litert/litert_cc_sdk/
engines/litert/litert_cc_sdk.zip
engines/litert/litert-src.tar.gz
engines/litert/LiteRT-*/
